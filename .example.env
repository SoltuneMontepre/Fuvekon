NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Google Sign-In (optional – omit to hide the Google login button)
# Create OAuth 2.0 Client ID (Web application) at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# AWS S3 Configuration (for file uploads)
NLF_AWS_REGION=us-east-1
NLF_AWS_ACCESS_KEY_ID=your-access-key-id
NLF_AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=your-bucket-name
